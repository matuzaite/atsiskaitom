{
  "name": "expense-splitter",
  "version": "1.0.0",
  "description": "Friend-group expense splitter with debt simplification",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch server/index.js",
    "dev:web": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "test": "node --test"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "vite": "^5.4.0"
  }
}
